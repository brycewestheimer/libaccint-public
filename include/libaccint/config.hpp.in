// config.hpp.in - LibAccInt build configuration
// This file is generated by CMake from config.hpp.in

#pragma once

// Version information
#define LIBACCINT_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define LIBACCINT_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define LIBACCINT_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define LIBACCINT_VERSION "@PROJECT_VERSION@"
#define LIBACCINT_VERSION_PRERELEASE "@LIBACCINT_PRERELEASE@"
#define LIBACCINT_VERSION_FULL "@LIBACCINT_VERSION_FULL@"

// Backend availability
#cmakedefine01 LIBACCINT_USE_CUDA
#cmakedefine01 LIBACCINT_USE_MPI
#cmakedefine01 LIBACCINT_USE_OPENMP
#cmakedefine01 LIBACCINT_GPU_ONLY
#cmakedefine01 LIBACCINT_ENABLE_CPU_GENERATED_REGISTRY

// Kernel dispatch strategy: "handwritten", "generated", or "optimal"
#define LIBACCINT_KERNEL_DISPATCH "@LIBACCINT_KERNEL_DISPATCH@"

// Vectorization configuration
#define LIBACCINT_VECTOR_ISA "@LIBACCINT_VECTOR_ISA@"
#define LIBACCINT_VECTOR_WIDTH @LIBACCINT_VECTOR_WIDTH@

// Maximum angular momentum for generated kernels (set by CMake option)
// 0=S, 1=P, 2=D, 3=F, 4=G, 5=H, 6=I
// Overrides the default in config/max_am.hpp when set via -DLIBACCINT_MAX_AM=<N>
#define LIBACCINT_MAX_AM @LIBACCINT_MAX_AM@

// K-range boundaries for contraction classification (set by CMake option)
// SmallK:  K <= LIBACCINT_SMALL_K_MAX
// MediumK: LIBACCINT_SMALL_K_MAX < K <= LIBACCINT_MEDIUM_K_MAX
// LargeK:  K > LIBACCINT_MEDIUM_K_MAX
#define LIBACCINT_SMALL_K_MAX @LIBACCINT_SMALL_K_MAX@
#define LIBACCINT_MEDIUM_K_MAX @LIBACCINT_MEDIUM_K_MAX@

#cmakedefine01 LIBACCINT_HAS_AVX512
#cmakedefine01 LIBACCINT_HAS_AVX2
#cmakedefine01 LIBACCINT_HAS_NEON
#cmakedefine01 LIBACCINT_HAS_SVE

namespace libaccint {

// Maximum derivative order supported
// 0 = no derivatives, 1 = first derivatives, 2 = second derivatives
inline constexpr int MAX_DERIVATIVE_ORDER = 0;

// Backend availability query functions
inline constexpr bool has_cuda_backend() noexcept {
    return LIBACCINT_USE_CUDA;
}

inline constexpr bool has_mpi_backend() noexcept {
    return LIBACCINT_USE_MPI;
}

inline constexpr bool has_openmp() noexcept {
    return LIBACCINT_USE_OPENMP;
}

inline constexpr bool gpu_only() noexcept {
    return LIBACCINT_GPU_ONLY;
}

inline constexpr bool cpu_generated_registry_enabled() noexcept {
    return LIBACCINT_ENABLE_CPU_GENERATED_REGISTRY;
}

// Version query function
inline constexpr const char* version() noexcept {
    return LIBACCINT_VERSION;
}

// Vectorization information
inline constexpr const char* vector_isa() noexcept {
    return LIBACCINT_VECTOR_ISA;
}

inline constexpr int vector_width() noexcept {
    return LIBACCINT_VECTOR_WIDTH;
}

inline constexpr bool has_avx512() noexcept {
    return LIBACCINT_HAS_AVX512;
}

inline constexpr bool has_avx2() noexcept {
    return LIBACCINT_HAS_AVX2;
}

inline constexpr bool has_neon() noexcept {
    return LIBACCINT_HAS_NEON;
}

inline constexpr bool has_sve() noexcept {
    return LIBACCINT_HAS_SVE;
}

// Kernel dispatch strategy query
inline constexpr const char* kernel_dispatch_strategy() noexcept {
    return LIBACCINT_KERNEL_DISPATCH;
}

inline constexpr int small_k_max() noexcept {
    return LIBACCINT_SMALL_K_MAX;
}

inline constexpr int medium_k_max() noexcept {
    return LIBACCINT_MEDIUM_K_MAX;
}

} // namespace libaccint
